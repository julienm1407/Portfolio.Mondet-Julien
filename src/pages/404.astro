---
import Layout from "../layouts/Layout.astro";

export const prerender = true;
---

<Layout title="Page introuvable — Portfolio">
  <main class="mx-auto max-w-2xl px-4 py-24 text-center">
    <h1 class="text-2xl font-extrabold uppercase tracking-tight text-primary">Page introuvable</h1>
    <p class="mt-3 text-sm font-medium text-ink/60">La page demandée n’existe pas ou a été déplacée.</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center justify-center rounded-card border-2 border-primary bg-primary px-5 py-2 text-xs font-bold uppercase tracking-wide text-white shadow-card"
    >
      Retour à l’accueil
    </a>
  </main>
</Layout>
