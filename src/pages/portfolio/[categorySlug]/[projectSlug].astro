---
import Layout from "../../../layouts/Layout.astro";
import { ProjectArticle } from "../../../components/ProjectArticle";
import { getCategoryBySlug } from "../../../lib/categories";
import { getAllProjectRoutes, getProjectBySlugs } from "../../../lib/projects";
import { sitePath } from "../../../lib/homeHref";

export const prerender = true;

export async function getStaticPaths() {
  return getAllProjectRoutes().map(({ categorySlug, projectSlug }) => ({
    params: { categorySlug, projectSlug },
  }));
}

const { categorySlug, projectSlug } = Astro.params;
const project = getProjectBySlugs(categorySlug ?? "", projectSlug ?? "");
const category = getCategoryBySlug(categorySlug ?? "");

if (!project || !category) {
  return Astro.redirect(sitePath("/404.html"));
}
---

<Layout title={`${project.title} — ${category.shortTitle}`} description={project.content.summary ?? project.title}>
  <ProjectArticle client:load project={project} category={category} />
</Layout>
