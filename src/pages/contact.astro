---
import Layout from "../layouts/Layout.astro";
import { SiteFooter } from "../components/SiteFooter";
import { employerReviews, site } from "../content/site";
import { getHomeHref } from "../lib/homeHref";
import { phoneDisplayToTelHref } from "../lib/phoneTelHref";

export const prerender = true;

const homeHref = getHomeHref();

const email = site.contact.email?.trim() ?? "";
const mailSubjectRaw = site.contact.mailSubject?.trim() ?? "";
const mailtoHref = email
  ? mailSubjectRaw
    ? `mailto:${email}?subject=${encodeURIComponent(mailSubjectRaw)}`
    : `mailto:${email}`
  : null;
const linkedinUrl = (site.contact.linkedin?.trim() ?? "") || null;
const phoneDisplay = site.contact.phone?.trim() ?? "";
const phoneTelHref = phoneDisplayToTelHref(phoneDisplay);

function ratingAriaLabel(rating: number): string {
  const label = Number.isInteger(rating) ? String(rating) : String(rating).replace(".", ",");
  return `Note : ${label} sur 5`;
}
---

<Layout
  title={`Contact — ${site.name}`}
  description="Me contacter par téléphone, e-mail ou LinkedIn, et parcourir les retours d’anciennes collaborations."
>
  <header class="sticky top-0 z-50 border-b border-line bg-surface/95 shadow-sm backdrop-blur supports-[backdrop-filter]:bg-surface/80">
    <div class="site-header-cap" aria-hidden="true">
      <div class="site-header-cap__main"></div>
      <div class="site-header-cap__accent"></div>
    </div>
    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-8 lg:py-9">
      <a
        href={homeHref}
        class="relative z-10 inline-flex min-h-[44px] min-w-[44px] items-center gap-2 py-2 text-xs font-bold uppercase tracking-wider text-primary hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 touch-manipulation"
      >
        <span aria-hidden="true">←</span>
        Accueil
      </a>
      <div class="mt-5 border-l-4 border-accent pl-4 sm:mt-6">
        <p class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-ink/50">Contact</p>
        <h1 class="mt-1 text-balance text-3xl font-extrabold uppercase tracking-tight text-primary sm:text-4xl">
          Échangeons
        </h1>
        <p class="mt-2 max-w-2xl text-pretty text-sm font-medium leading-relaxed text-ink/70">
          Une mission, une question ou une idée de collaboration — choisissez le canal qui vous convient.
        </p>
      </div>
    </div>
  </header>

  <main class="bg-muted pb-16 pt-8 sm:pt-10">
    <div class="mx-auto max-w-6xl space-y-12 px-4 sm:px-6">
      <section aria-labelledby="contact-canaux">
        <h2 id="contact-canaux" class="sr-only">Canaux de contact</h2>
        <div class="grid gap-5 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
          {
            mailtoHref ? (
              <a
                href={mailtoHref}
                class="group flex flex-col justify-between rounded-card border-2 border-line bg-surface p-6 shadow-card transition hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-card-hover sm:p-8"
              >
                <div>
                  <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="stroke-current" stroke-width="2" aria-hidden="true">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke-linecap="round" stroke-linejoin="round"></path>
                      <path d="m22 6-10 7L2 6" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </div>
                  <p class="mt-5 text-[10px] font-extrabold uppercase tracking-[0.2em] text-ink/45">E-mail</p>
                  <p class="mt-2 text-lg font-extrabold uppercase tracking-tight text-ink">M’écrire directement</p>
                  <p class="mt-2 text-pretty text-sm leading-relaxed text-ink/65">
                    Ouvre votre messagerie avec une ligne d’objet déjà remplie — il vous suffit de rédiger votre message.
                  </p>
                </div>
                <p class="mt-6 text-sm font-bold text-primary transition group-hover:text-accent">{email} →</p>
              </a>
            ) : (
              <div class="flex flex-col justify-between rounded-card border-2 border-dashed border-line bg-surface p-6 sm:p-8">
                <p class="text-sm font-medium text-ink/65">
                  Renseignez <code class="rounded bg-muted px-1 py-0.5 text-xs">site.contact.email</code> dans{" "}
                  <code class="rounded bg-muted px-1 py-0.5 text-xs">src/content/site.ts</code> pour activer le lien e-mail.
                </p>
              </div>
            )
          }

          {
            phoneTelHref ? (
              <a
                href={phoneTelHref}
                class="group flex flex-col justify-between rounded-card border-2 border-line bg-surface p-6 shadow-card transition hover:-translate-y-0.5 hover:border-accent/50 hover:shadow-card-hover sm:p-8"
              >
                <div>
                  <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10 text-accent">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="stroke-current" stroke-width="2" aria-hidden="true">
                      <path
                        d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      ></path>
                    </svg>
                  </div>
                  <p class="mt-5 text-[10px] font-extrabold uppercase tracking-[0.2em] text-ink/45">Téléphone</p>
                  <p class="mt-2 text-lg font-extrabold uppercase tracking-tight text-ink">M’appeler</p>
                  <p class="mt-2 text-pretty text-sm leading-relaxed text-ink/65">
                    Idéal pour un premier contact rapide ou pour convenir d’un entretien. Appui long sur le numéro sur mobile pour composer.
                  </p>
                </div>
                <p class="mt-6 text-sm font-bold text-accent transition group-hover:text-primary">{phoneDisplay} →</p>
              </a>
            ) : null
          }

          {
            linkedinUrl ? (
              <a
                href={linkedinUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col justify-between rounded-card border-2 border-line bg-surface p-6 shadow-card transition hover:-translate-y-0.5 hover:border-[#0A66C2]/50 hover:shadow-card-hover sm:p-8"
              >
                <div>
                  <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#0A66C2]/10 text-[#0A66C2]">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path
                        d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                      ></path>
                    </svg>
                  </div>
                  <p class="mt-5 text-[10px] font-extrabold uppercase tracking-[0.2em] text-ink/45">LinkedIn</p>
                  <p class="mt-2 text-lg font-extrabold uppercase tracking-tight text-ink">Voir mon profil</p>
                  <p class="mt-2 text-pretty text-sm leading-relaxed text-ink/65">
                    Parcours détaillé, recommandations et actualités — idéal pour un premier aperçu professionnel.
                  </p>
                </div>
                <p class="mt-6 text-sm font-bold text-[#0A66C2] transition group-hover:underline">Ouvrir LinkedIn →</p>
              </a>
            ) : (
              <div class="flex flex-col justify-between rounded-card border-2 border-dashed border-line bg-surface p-6 sm:p-8">
                <p class="text-sm font-medium text-ink/65">
                  Renseignez <code class="rounded bg-muted px-1 py-0.5 text-xs">site.contact.linkedin</code> dans{" "}
                  <code class="rounded bg-muted px-1 py-0.5 text-xs">src/content/site.ts</code> pour activer le lien LinkedIn.
                </p>
              </div>
            )
          }
        </div>
      </section>

      <section class="border-t border-line pt-12" aria-labelledby="avis-employeurs">
        <div class="mb-8 max-w-2xl border-l-4 border-primary pl-4">
          <p class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-ink/50">Recommandations</p>
          <h2 id="avis-employeurs" class="mt-1 text-balance text-2xl font-extrabold uppercase tracking-tight text-primary sm:text-3xl">
            Retours d’anciennes collaborations
          </h2>
          <p class="mt-2 text-pretty text-sm font-medium leading-relaxed text-ink/65">
            Notes et extraits de retours reçus en contexte pro.
          </p>
        </div>

        {
          employerReviews.length > 0 ? (
            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6">
              {employerReviews.map((review) => (
                <article class="flex flex-col rounded-card border border-line bg-surface p-5 shadow-card sm:p-6" set:key={review.company}>
                  <div class="flex flex-wrap items-center justify-between gap-3 border-b border-line pb-4">
                    <div class="flex min-w-0 flex-1 flex-col gap-2 sm:flex-row sm:items-center sm:gap-3">
                      {
                        review.logoUrl ? (
                          <div
                            class="flex h-[4.25rem] w-[4.25rem] shrink-0 items-center justify-center overflow-hidden rounded-full bg-white p-1.5 ring-2 ring-line/40 sm:h-[4.75rem] sm:w-[4.75rem] sm:p-2 dark:bg-white dark:ring-line/50"
                          >
                            <img
                              src={review.logoUrl}
                              alt=""
                              width="76"
                              height="76"
                              loading="lazy"
                              decoding="async"
                              class="h-full w-full origin-center object-contain object-center will-change-transform"
                              style={review.logoScale != null ? { transform: `scale(${review.logoScale})` } : undefined}
                            />
                          </div>
                        ) : null
                      }
                      <p class="min-w-0 text-xs font-extrabold uppercase tracking-wide text-ink">{review.company}</p>
                    </div>
                    <div class="flex gap-px text-lg leading-none" aria-label={ratingAriaLabel(review.rating)}>
                      {[1, 2, 3, 4, 5].map((star) => {
                        const r = review.rating;
                        const full = r >= star;
                        const half = !full && r >= star - 0.5;
                        return (
                          <span set:key={star} class="relative inline-flex h-[1em] w-[0.65em] shrink-0 items-center justify-center" aria-hidden="true">
                            {full ? (
                              <span class="text-amber-500 dark:text-amber-400">★</span>
                            ) : half ? (
                              <span class="relative inline-flex h-[1em] w-[0.65em] items-center justify-center">
                                <span class="text-ink/22 dark:text-ink/35">☆</span>
                                <span class="absolute left-0 top-0 flex h-[1em] w-1/2 overflow-hidden">
                                  <span class="inline-flex min-w-[0.65em] items-center justify-center text-amber-500 dark:text-amber-400">★</span>
                                </span>
                              </span>
                            ) : (
                              <span class="text-ink/22 dark:text-ink/35">☆</span>
                            )}
                          </span>
                        );
                      })}
                    </div>
                  </div>
                  <blockquote class="mt-4 flex-1">
                    <p class="text-pretty text-sm font-normal leading-relaxed text-ink/85">
                      <span class="text-primary/70" aria-hidden="true">«&nbsp;</span>
                      {review.quote}
                      <span class="text-primary/70" aria-hidden="true">&nbsp;»</span>
                    </p>
                  </blockquote>
                  {review.attribution ? (
                    <p class="mt-4 text-[11px] font-semibold uppercase tracking-wider text-ink/45">— {review.attribution}</p>
                  ) : null}
                </article>
              ))}
            </div>
          ) : (
            <p class="rounded-card border border-dashed border-line bg-surface p-8 text-center text-sm text-ink/55">
              Ajoutez des entrées dans <code class="rounded bg-muted px-1 py-0.5 text-xs">employerReviews</code> pour afficher des avis ici.
            </p>
          )
        }
      </section>
    </div>
  </main>

  <SiteFooter omitContactPageLink homeHref={homeHref} />
</Layout>
